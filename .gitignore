# Data and model artefacts — must live in DVC, never in git.
# .dvc pointer files MUST be tracked, so re-include them explicitly.
/data/*
!/data/*.dvc
!/data/.gitignore
/models/*
!/models/*.dvc
!/models/.gitignore
*.csv
*.json
*.h5
*.npz
*.pkl
*.ckpt
*.pth
*.pt
*.onnx
*.engine
*.plan

# DVC
/.dvc/cache
/.dvc/tmp
/.dvc/plots

